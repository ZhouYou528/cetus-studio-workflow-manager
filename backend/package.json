{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:apply": "wrangler d1 execute studio_db --local --file=./schema.sql",
    "db:seed": "wrangler d1 execute studio_db --local --file=./seed.sql",
    "db:apply:remote": "wrangler d1 execute studio_db --remote --file=./schema.sql",
    "db:seed:remote": "wrangler d1 execute studio_db --remote --file=./seed.sql"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260510.1",
    "typescript": "^5.7.2",
    "wrangler": "^4.90.0"
  }
}
